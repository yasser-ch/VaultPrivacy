<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚀 Atelier Final"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="Combinaison de toutes les techniques : Photo Picker sans permission, localisation avec rationale dialog, et principe du moindre privilège."
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:lineSpacingExtra="4dp"/>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/llActions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/cardDesc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectPhoto"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="🖼️ Photo"
                android:textAllCaps="false"
                android:layout_marginEnd="8dp"
                app:backgroundTint="@color/purple_primary"
                app:cornerRadius="14dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGetLocation"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="📍 Position"
                android:textAllCaps="false"
                app:backgroundTint="@color/teal_accent"
                app:cornerRadius="14dp"/>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPhoto"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card"
            app:layout_constraintTop_toBottomOf="@id/llActions"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivPhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Photo sélectionnée"/>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardResult"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card_dark"
            app:layout_constraintTop_toBottomOf="@id/cardPhoto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvPhotoInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📷 Aucune photo"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvLocationInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 Aucune localisation"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="monospace"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/VaultButtonOutlined"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="← Retour"
            android:textColor="@color/text_muted"
            android:layout_marginTop="16dp"
            app:strokeColor="@color/purple_dim"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/cardResult"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>